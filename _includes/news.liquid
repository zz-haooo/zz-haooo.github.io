<div class="news">
  {% if site.news != blank %}
    {% assign news = site.news | reverse %}
    {% assign news_size = news | size %}

    {% comment %}
      Behavior:
      - On the home page (include.limit == true) we always show the first 2
        news items, and collapse the rest into a <details> dropdown that the
        user can expand. The page-wide `page.announcements.limit` is ignored
        on purpose so that the collapsed dropdown can reveal everything.
      - On the dedicated /news/ page we keep the original behavior: render
        every item in a single scrollable table.
    {% endcomment %}

    {% if include.limit %}
      {% assign visible_count = 2 %}
    {% else %}
      {% assign visible_count = news_size %}
    {% endif %}

    <div class="table-responsive">
      <table class="table table-sm table-borderless news-table-visible">
        {% for item in news limit: visible_count %}
          <tr>
            <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
            <td>
              {% if item.inline %}
                {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
              {% else %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>

    {% if include.limit and news_size > visible_count %}
      <details class="news-collapsible">
        <summary aria-label="Toggle older news">
          <svg class="news-chevron" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3.5 6 L8 10.5 L12.5 6" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </summary>
        <div class="table-responsive">
          <table class="table table-sm table-borderless news-table-collapsed">
            {% for item in news offset: visible_count %}
              <tr>
                <th scope="row" style="width: 20%">{{ item.date | date: '%b %d, %Y' }}</th>
                <td>
                  {% if item.inline %}
                    {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
                  {% else %}
                    <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
                  {% endif %}
                </td>
              </tr>
            {% endfor %}
          </table>
        </div>
      </details>
    {% endif %}
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
